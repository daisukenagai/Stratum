---
import { getNavLink } from '../lib/blog-helpers.ts'
import { Image } from 'astro:assets'
import ImageLink from '../atoms/ImageLink.astro'
import faceImage from '../../images/face.jpg'
import logoNote from '../../images/logo_note.png'
import logoYoutrust from '../../images/logo_youtrust.png'
import logoLinkedin from '../../images/logo_linkedin.png'

